<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hechos - MetaMapa</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/hechos.css">
</head>

<body style="background: #f8f6f2; min-height: 100vh;">

{{> navbar_user}}

<div class="container-fluid py-5">

    <h1 class="display-5 fw-bold mb-4 text-center" style="color: #333;">
        Hechos Reportados
    </h1>

    {{#if statusform}}
        <div class="alert alert-{{statusform_class}} text-center">
            {{statusform_message}}
        </div>
    {{/if}}

    <!-- ================= BUSCADOR ================= -->
    <form action="/hechos" method="GET" class="mb-4">
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Buscar por título o descripción..."
                   name="q"
                   value="{{consulta}}">
            <button class="btn btn-outline-secondary" type="submit">
                Buscar
            </button>
        </div>
    </form>

    <!-- ================= BOTÓN NUEVO HECHO ================= -->
    {{#if usuarioUsername}}
        <div class="d-flex justify-content-center gap-2 mb-4">
            <button class="btn btn-success" onclick="abrirModalHecho()">
                Reportar Nuevo Hecho
            </button>
        </div>
    {{/if}}

    <!-- ================= LISTADO (IGUAL ADMIN) ================= -->
    <div class="list-group">
        {{#if hechos}}
            {{#each hechos}}
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">

                    <button
                            class="btn btn-link p-0 text-start"
                            onclick="abrirModalDetalleHecho(this)"
                            data-id="{{id}}"
                            data-titulo="{{titulo}}"
                            data-descripcion="{{descripcion}}"
                            data-categoria="{{categoria}}"
                            data-provincia="{{provincia.nombre}}"
                            data-fecha="{{fechaAcontecimiento}}"
                            data-origen="{{origen}}"
                    >
                        {{titulo}}
                    </button>

                </div>
            {{/each}}
        {{else}}
            {{#if consulta}}
                <p class="text-muted">
                    No se encontraron hechos que coincidan con "{{consulta}}".
                </p>
            {{else}}
                <p class="text-muted">
                    No hay hechos registrados.
                </p>
            {{/if}}
        {{/if}}
    </div>
</div>

<!-- ================= MODAL NUEVO HECHO ================= -->

<div id="overlay-hecho" class="overlay d-none">
    <div class="modal-hecho">

        <h3 class="mb-4 text-center">
            Reportar Nuevo Hecho
        </h3>

        <form action="/hechos" method="POST">

            <!-- Fuente -->
            <div class="mb-3">
                <label class="form-label">Fuente *</label>
                <select name="fuenteId" class="form-select" required>
                    <option value="">Seleccionar fuente...</option>
                    {{#each fuentes}}
                        <option value="{{id}}">
                            {{nombre}} - {{tipo}}
                        </option>
                    {{/each}}
                </select>
            </div>

            <!-- Título -->
            <div class="mb-3">
                <label class="form-label">Título *</label>
                <input type="text" name="titulo" class="form-control" required>
            </div>

            <!-- Descripción -->
            <div class="mb-3">
                <label class="form-label">Descripción *</label>
                <textarea name="descripcion" class="form-control" rows="4" required></textarea>
            </div>

            <!-- Categoría / Provincia / Fecha -->
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Categoría *</label>
                    <select name="categoria" class="form-select" required>
                        <option value="">Seleccionar...</option>
                        {{#each categorias}}
                            <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Provincia *</label>
                    <select name="provincia" class="form-select" required>
                        <option value="">Seleccionar...</option>
                        {{#each provincias}}
                            <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Fecha *</label>
                    <input type="date" name="fechaAcontecimiento" class="form-control" required>
                </div>
            </div>

            <!-- Coordenadas -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Latitud</label>
                    <input type="number" step="any" name="latitud" class="form-control">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Longitud</label>
                    <input type="number" step="any" name="longitud" class="form-control">
                </div>
            </div>

            <!-- Multimedia -->
            <div class="mb-4">
                <h5 class="mb-3">Multimedia (Opcional)</h5>

                <div class="mb-3">
                    <label class="form-label">URL del recurso</label>
                    <input type="url" name="multimediaUrl" class="form-control">
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo</label>
                        <select name="multimediaTipo" class="form-select">
                            <option value="">Seleccionar...</option>
                            <option value="IMAGEN">Imagen</option>
                            <option value="VIDEO">Video</option>
                            <option value="AUDIO">Audio</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Descripción</label>
                        <input type="text" name="multimediaDescripcion" class="form-control">
                    </div>
                </div>
            </div>

            <!-- Botones -->
            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="button" class="btn btn-secondary" onclick="cerrarModalHecho()">
                    Cancelar
                </button>
                <button type="submit" class="btn btn-primary">
                    Guardar
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ================= MODAL DETALLE HECHO (IGUAL ADMIN) ================= -->

<div class="modal fade" id="modalDetalleHecho" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitulo"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p id="modalDescripcion" class="fs-5"></p>

                <ul class="list-group mb-3">
                    <li class="list-group-item">
                        <strong>Categoría:</strong> <span id="modalCategoria"></span>
                    </li>
                    <li class="list-group-item">
                        <strong>Provincia:</strong> <span id="modalProvincia"></span>
                    </li>
                    <li class="list-group-item">
                        <strong>Fecha:</strong> <span id="modalFecha"></span>
                    </li>
                    <li class="list-group-item">
                        <strong>Origen:</strong> <span id="modalOrigen"></span>
                    </li>
                </ul>

                <hr>

                <h5>Contenido Multimedia</h5>
                <div class="text-muted fst-italic">
                    La carga de multimedia se gestiona desde el detalle completo.
                </div>

            </div>

            <div class="modal-footer">
                <a id="linkDetalle" class="btn btn-outline-primary" target="_blank">
                    Ver detalle completo
                </a>
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function abrirModalHecho() {
        document.getElementById("overlay-hecho").classList.remove("d-none");
    }

    function cerrarModalHecho() {
        document.getElementById("overlay-hecho").classList.add("d-none");
    }

    function abrirModalDetalleHecho(btn) {
        document.getElementById("modalTitulo").innerText = btn.dataset.titulo;
        document.getElementById("modalDescripcion").innerText = btn.dataset.descripcion;
        document.getElementById("modalCategoria").innerText = btn.dataset.categoria;
        document.getElementById("modalProvincia").innerText = btn.dataset.provincia;
        document.getElementById("modalFecha").innerText = btn.dataset.fecha;
        document.getElementById("modalOrigen").innerText = btn.dataset.origen;

        document.getElementById("linkDetalle").href = `/hechos/${btn.dataset.id}`;

        new bootstrap.Modal(
            document.getElementById("modalDetalleHecho")
        ).show();
    }
</script>

</body>
</html>
