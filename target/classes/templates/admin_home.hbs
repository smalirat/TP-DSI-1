<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - MetaMapa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/admin_home.css">
</head>
<body style="background: #f8f6f2; min-height: 100vh;">

<!-- Include Admin Navbar -->
{{> navbar_admin}}

<div class="admin-home-container">
    <div class="welcome-content">
        <h1 class="admin-title mb-4">Panel de Administración</h1>
        <p class="lead">Bienvenido al panel de control de MetaMapa.</p>
    </div>
    
    <hr class="my-4">
    <h3 class="mb-3">Tareas Asincrónicas</h3>


    <div class="row">
        <div class="col-md-6">
            <div class="card admin-card mb-4">
                <div class="card-body">
                    <h5 class="card-title">1. Actualizar Fuentes Externas</h5>
                    <p class="card-text">Sincroniza los hechos de las fuentes Proxy (APIs, CSVs) y recalcula los Agregadores.</p>
                    <form action="/admin/fuentes/actualizar" method="POST">
                        <button type="submit" class="btn btn-warning">Ejecutar Actualización de Fuentes</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card admin-card mb-4">
                <div class="card-body">
                    <h5 class="card-title">2. Recalcular Consensos</h5>
                    <p class="card-text">Aplica los algoritmos de consenso (Absoluta, Mayoría) a todas las colecciones "Curadas".</p>
                    <form action="/admin/colecciones/recalcular" method="POST">
                        <button type="submit" class="btn btn-primary">Ejecutar Recálculo de Consenso</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


</body>
</html>