<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Agregar Multimedia a Hecho: {{hecho.titulo}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<h1 class="mb-4">Agregar Multimedia al Hecho "{{hecho.titulo}}"</h1>

<form action="/hechos/{{hecho.id}}/multimedia" method="POST" class="mt-3">
    <div class="mb-3">
        <label for="multimediaUrl" class="form-label">URL de la Imagen o Video</label>
        <input type="url" class="form-control" id="multimediaUrl" name="multimediaUrl"
               placeholder="https://ejemplo.com/imagen.jpg" required>
    </div>

    <div class="mb-3">
        <label for="multimediaTipo" class="form-label">Tipo de Contenido</label>
        <select class="form-select" id="multimediaTipo" name="multimediaTipo" required>
            <option value="">Seleccionar tipo...</option>
            <option value="IMAGEN">Imagen</option>
            <option value="VIDEO">Video</option>
        </select>
    </div>

    <div class="mb-3">
        <label for="descripcion" class="form-label">Descripción (Opcional)</label>
        <input type="text" class="form-control" id="descripcion" name="descripcion" maxlength="255">
    </div>

    <button type="submit" class="btn btn-primary">Agregar Multimedia</button>
    <a href="/hechos/{{hecho.id}}" class="btn btn-secondary">Cancelar</a>
</form>

</body>
</html>