<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estadísticas - MetaMapa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/estadisticas.css">
</head>
<body style="background: #f8f6f2; min-height: 100vh;">
    
    <!-- Include User Navbar -->
    {{> navbar_user}}

    <!-- Main Content -->
    <div class="container-fluid py-5">
        <h1 class="display-5 fw-bold mb-4 text-center">Estadísticas Públicas</h1>
        
        <form action="/estadisticas" method="GET" class="mb-4">
            <div class="input-group">
                <select name="tipo" class="form-select">
                    <option value="">Filtrar por tipo...</option>
                    {{#each tipos}}
                        <option value="{{this}}" {{#if (eq this ../seleccionado)}}selected{{/if}}>{{this}}</option>
                    {{/each}}
                </select>
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <button type="button" onclick="window.location.href='/estadisticas'" class="btn btn-outline-secondary">Limpiar</button>
            </div>
        </form>

        <table class="table table-striped mt-4">
            <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Nombre Reporte</th>
                <th scope="col">Tipo</th>
                <th scope="col">Fecha Cálculo</th>
                <th scope="col">Acciones</th>
            </tr>
            </thead>
            <tbody>
            {{#if estadisticas}}
                {{#each estadisticas}}
                    <tr>
                        <td>{{id}}</td>
                        <td><a href="/estadisticas/{{id}}">{{nombre}}</a></td>
                        <td><span class="badge bg-secondary">{{tipo}}</span></td>
                        <td>{{fechaCalculo}}</td>
                        <td>
                            <a href="/estadisticas/{{id}}" class="btn btn-sm btn-primary">Ver Detalle</a>
                            <a href="/estadisticas/{{id}}/csv" class="btn btn-sm btn-success">Descargar CSV</a>
                        </td>
                    </tr>
                {{/each}}
            {{else}}
                <tr>
                    <td colspan="5" class="text-center">No hay estadísticas públicas disponibles.</td>
                </tr>
            {{/if}}
            </tbody>
        </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

