<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - Estadísticas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/estadisticas.css">
</head>

<body style="background: #f8f6f2; min-height: 100vh;">

{{> navbar_admin}}

<div class="container-fluid py-5">

    <h1 class="display-5 fw-bold mb-4" style="color: #333;">
        Reportes Estadísticos
    </h1>

    {{#if statusform}}
        <div class="alert alert-{{statusform_class}} text-center">
            {{statusform_message}}
        </div>
    {{/if}}

    <!-- BOTONES SUPERIORES -->
    <div class="d-flex justify-content-center gap-4 mb-4">
        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#modalNuevaEstadistica">
            Generar Nuevo Reporte
        </button>

        <a href="/admin" class="btn btn-secondary">
            Volver al Panel Admin
        </a>
    </div>

    <!-- FILTRO -->
    <form action="/admin/estadisticas" method="GET" class="mb-4">
        <div class="input-group">
            <select name="tipo" class="form-select">
                <option value="">Filtrar por tipo...</option>
                {{#each tipos}}
                    <option value="{{this}}" {{#if (eq this ../seleccionado)}}selected{{/if}}>
                        {{this}}
                    </option>
                {{/each}}
            </select>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/estadisticas" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>

    <!-- TABLA -->
    <div class="table-responsive">
        <table class="table table-striped mt-4">
            <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Parámetros</th>
                <th>Fecha Cálculo</th>
                <th>Archivo CSV</th>
            </tr>
            </thead>
            <tbody>
            {{#if estadisticas}}
                {{#each estadisticas}}
                    <tr>
                        <td>{{id}}</td>
                        <td>
                            <a href="/admin/estadisticas/{{id}}">
                                {{nombre}}
                            </a>
                        </td>
                        <td>
                            <span class="badge bg-secondary">
                                {{tipo}}
                            </span>
                        </td>
                        <td>
                            {{#if parametros}}
                                {{parametros}}
                            {{else}}
                                N/A
                            {{/if}}
                        </td>
                        <td>{{fechaCalculo}}</td>
                        <td>
                            <small>{{rutaArchivoCSV}}</small><br>
                            <a href="/admin/estadisticas/{{id}}/csv"
                               class="btn btn-sm btn-success mt-1">
                                Descargar CSV
                            </a>
                        </td>
                    </tr>
                {{/each}}
            {{else}}
                <tr>
                    <td colspan="6" class="text-center">
                        No hay estadísticas generadas.
                    </td>
                </tr>
            {{/if}}
            </tbody>
        </table>
    </div>
</div>

<!-- ================= MODAL ================= -->

<div class="modal fade" id="modalNuevaEstadistica" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <form action="/admin/estadisticas" method="POST">

                <div class="modal-header">
                    <h5 class="modal-title">Generar Nueva Estadística</h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Nombre del Reporte *</label>
                        <input type="text" name="nombre"
                               class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo de Estadística *</label>
                        <select name="tipo"
                                class="form-select"
                                required
                                onchange="mostrarCamposDinamicos(this.value)">
                            <option value="">Seleccionar tipo...</option>
                            {{#each tipos}}
                                <option value="{{this}}">{{this}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="mb-3" id="campoCategoria" style="display:none;">
                        <label class="form-label">Categoría</label>
                        <select id="categoria" name="categoria"
                                class="form-select">
                            <option value="">Seleccionar categoría...</option>
                            {{#each todasLasCategorias}}
                                <option value="{{this}}">
                                    {{this}}
                                </option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="mb-3" id="campoColeccion" style="display:none;">
                        <label class="form-label">Colección</label>
                        <select id="coleccionHandle" name="coleccionHandle"
                                class="form-select">
                            <option value="">Seleccionar colección...</option>
                            {{#each todasLasColecciones}}
                                <option value="{{handle}}">
                                    {{titulo}} ({{handle}})
                                </option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="esPublica"
                               id="esPublica">
                        <label class="form-check-label" for="esPublica">
                            Marcar como Pública
                        </label>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="btn btn-success">
                        Generar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function mostrarCamposDinamicos(tipo) {
        const campoCategoria = document.getElementById('campoCategoria');
        const campoColeccion = document.getElementById('campoColeccion');
        const categoria = document.getElementById('categoria');
        const coleccion = document.getElementById('coleccionHandle');

        const necesitaCategoria =
            tipo === 'PROVINCIA_MAS_HECHOS_POR_CATEGORIA' ||
            tipo === 'HORA_PICO_POR_CATEGORIA';

        const necesitaColeccion =
            tipo === 'HECHOS_POR_PROVINCIA_COLECCION';

        campoCategoria.style.display = necesitaCategoria ? 'block' : 'none';
        categoria.required = necesitaCategoria;

        campoColeccion.style.display = necesitaColeccion ? 'block' : 'none';
        coleccion.required = necesitaColeccion;
    }
    if (window.location.search.includes('formStatus')) {
        const url = new URL(window.location);
        url.searchParams.delete('formStatus');
        window.history.replaceState({}, document.title, url.pathname + url.search);
    }
</script>

</body>
</html>
