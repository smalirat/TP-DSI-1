<!DOCTYPE html>
<html lang="es">
<head>
    <title>Fuentes de Datos - MetaMapa</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
</head>

<body style="background: #f8f6f2; min-height: 100vh;">

{{> navbar_admin}}

<div class="container-fluid py-5">

    <h1 class="display-5 fw-bold mb-4" style="color: #333;">
        Fuentes de Datos Disponibles
    </h1>

    <!-- STATUS FORM -->
    {{#if statusform}}
        <div class="alert alert-{{statusform_class}} text-center">
            {{statusform_message}}
        </div>
    {{/if}}

    <!-- BOTÓN CREAR FUENTE -->
    <div class="mb-4 d-flex justify-content-center">
        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#modalNuevaFuente">
            Crear Nueva Fuente
        </button>
    </div>

    <!-- TABLA -->
    <div class="table-responsive">
        <table class="table table-striped mt-3">
            <thead>
            <tr>
                <th>ID</th>
                <th class="text-center">Tipo de Fuente</th>
                <th class="text-end">Acciones</th>
            </tr>
            </thead>
            <tbody>
            {{#if fuentes}}
                {{#each fuentes}}
                    <tr>
                        <td>{{id}}</td>

                        <td class="text-center">
                            {{tipo_fuente}}
                        </td>

                        <td>
                            <div class="d-flex justify-content-center justify-content-md-end gap-2">
                                <a href="/fuentes/{{id}}/colecciones/nueva"
                                   class="btn btn-sm btn-success">
                                    Crear Colección
                                </a>

                                <a href="/fuentes/{{id}}/hechos"
                                   class="btn btn-sm btn-info">
                                    Ver Hechos
                                </a>
                            </div>
                        </td>
                    </tr>
                {{/each}}
            {{else}}
                <tr>
                    <td colspan="3" class="text-center">
                        No hay fuentes de datos creadas.
                    </td>
                </tr>
            {{/if}}
            </tbody>
        </table>
    </div>

</div>
</div>

<!-- ================= MODAL NUEVA FUENTE ================= -->

<div class="modal fade" id="modalNuevaFuente" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form action="/admin/fuentes" method="POST">

                <div class="modal-header">
                    <h5 class="modal-title">
                        Crear Nueva Fuente de Datos
                    </h5>
                    <button type="button"
                            class="btn-close "
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <p class="lead">
                        Esta acción es solo para administradores.
                        Se creará una <strong>Fuente de Datos Dinámica</strong> vacía.
                    </p>

                    <p>
                        Al confirmar, la fuente quedará disponible para recibir
                        contribuciones de usuarios.
                    </p>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-success">
                        Confirmar Creación
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
