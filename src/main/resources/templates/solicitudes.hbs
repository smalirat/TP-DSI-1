
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - Solicitudes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/solicitudes.css">
</head>
<body style="background: #f8f6f2; min-height: 100vh;">

<!-- Include Admin Navbar -->
{{> navbar_admin}}

<div class="container-fluid py-5">
    <h1 class="display-5 fw-bold mb-4" style="color: #333;">Solicitudes de Eliminación Pendientes</h1>
        <p class="subtitle">Aprobar o rechazar solicitudes de eliminación de hechos pendientes.</p>
    
    <div class="solicitudes-container">
        {{#if solicitudes}}
            {{#each solicitudes}}
                <div class="solicitud-item mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <a href="/hechos/{{hecho.id}}" class="solicitud-title">{{hecho.titulo}}</a>
                            <div class="solicitud-description mt-1">Motivo: {{#substring textoFundamentacion 100}}{{/substring}}...</div>
                            <div class="solicitud-date text-muted mt-1">Fecha de Solicitud: {{fechaSolicitud}}</div>
                        </div>
                        <div class="d-flex gap-2 ms-3">
                            <form action="/admin/solicitudes/{{id}}/aprobar" method="POST">
                                <button type="submit" class="btn btn-success btn-sm">Aprobar</button>
                            </form>
                            <form action="/admin/solicitudes/{{id}}/rechazar" method="POST">
                                <button type="submit" class="btn btn-danger btn-sm">Rechazar</button>
                            </form>
                        </div>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <div class="no-solicitudes">No hay solicitudes pendientes.</div>
        {{/if}}
    </div>
</div>

</body>
</html>