<!DOCTYPE html>
<html>
<head>
    <title>Hechos de Fuente {{fuente.id}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<h1>Hechos de la Fuente ID: {{fuente.id}}</h1>

{{#if listaDeHechos}}
    <p class="mt-2">
        Tipo de fuente:
        <span class="badge bg-{{#if_eq fuente.DTYPE 'DINAMICA'}}success{
            {else if_eq fuente.DTYPE 'ESTATICA'}}primary{{else}}secondary{{/if_eq}}"
            >{{fuente.DTYPE}}
        </span>
    </p>
    <p>Total de hechos: {{listaDeHechos.length}}</p>
    
    <div class="list-group mt-3">
        {{#each listaDeHechos}}
            <a href="/hechos/{{id}}" class="list-group-item list-group-item-action {{#if eliminado}}list-group-item-light text-muted text-decoration-line-through{{/if}}">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">{{titulo}}</h5>
                    {{#if eliminado}}
                        <span class="badge bg-secondary">Eliminado</span>
                    {{/if}}
                </div>
                <p class="mb-1 text-muted">{{descripcion}}</p>
                {{#if categoria}}
                    <small class="text-muted">Categoría: {{categoria}}</small>
                {{/if}}
            </a>
        {{/each}}
    </div>
{{else}}
    <div class="alert alert-info mt-3">
        <h5>Sin hechos</h5>
        <p>Esta fuente (Tipo: {{fuente.DTYPE}}) no tiene hechos asociados actualmente.</p>

        {{#ifeq fuente.DTYPE 'ESTATICA'}}
            <p class="mb-0"></p>
        {{/ifeq}}
        {{#ifeq fuente.DTYPE 'PROXY'}}
            <p class="mb-0"></p>
        {{/ifeq}}
    </div>
{{/if}}

<a href="/fuentes" class="btn btn-secondary mt-4">Volver a Fuentes</a>

</body>
</html>