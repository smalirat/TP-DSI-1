<!DOCTYPE html>
<html>
<head>
    <title>Hecho: {{hecho.titulo}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .multimedia-container img, .multimedia-container video, .multimedia-container audio {
            max-width: 100%;
            height: auto;
            margin-bottom: 1rem;
            border: 1px solid #ddd;
            border-radius: 5px;
        }
        .etiquetas-container .badge {
            margin-right: 5px;
        }
    </style>
</head>
<body class="container mt-4">

{{#if hecho}}
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h1 class="card-title">{{hecho.titulo}}</h1>
        </div>
        <div class="card-body">
            <p class="card-text fs-5">{{hecho.descripcion}}</p>

            <ul class="list-group list-group-flush mb-3">
                <li class="list-group-item"><strong>Categoría:</strong> {{hecho.categoria}}</li>
                <li class="list-group-item"><strong>Provincia:</strong> {{hecho.provincia.nombre}}</li> {{!-- Asume que Provincia tiene getNombre --}}
                <li class="list-group-item"><strong>Fecha del Hecho:</strong> {{hecho.fechaAcontecimiento}}</li>
                <li class="list-group-item"><strong>Origen:</strong> {{hecho.origen}}</li>
            </ul>

            <div class="mb-3 etiquetas-container">
                <strong>Etiquetas:</strong>
                {{#if hecho.etiquetas}}
                    {{#each hecho.etiquetas}}
                        <span class="badge bg-secondary fs-6">{{nombre}}</span>
                    {{/each}}
                {{else}}
                    <span class="text-muted fst-italic">Sin etiquetas asignadas.</span>
                {{/if}}
            </div>

            <hr>

            <div class="mt-4 multimedia-container">
                <h4>Contenido Multimedia Adjunto</h4>
                {{#if hecho.contenidoMultimedia}}
                    {{#each hecho.contenidoMultimedia}}
                        <div class="mb-3 border p-2 rounded bg-light">
                            {{#if (eq tipo 'IMAGEN')}}
                                <img src="{{url}}" alt="{{descripcion}}" class="img-fluid rounded">
                            {{/if}}
                            {{#if (eq tipo 'VIDEO')}}
                                <video controls width="100%" class="rounded">
                                    <source src="{{url}}" type="video/{{formato}}">
                                    Tu navegador no soporta la etiqueta de video.
                                    <a href="{{url}}" target="_blank">Ver video directamente</a>
                                </video>
                            {{/if}}
                            {{#if (eq tipo 'AUDIO')}} {{!-- Re-agregado bloque de Audio --}}
                                <audio controls class="w-100">
                                    <source src="{{url}}" type="audio/{{formato}}">
                                    Tu navegador no soporta la etiqueta de audio.
                                    <a href="{{url}}" target="_blank">Escuchar audio directamente</a>
                                </audio>
                            {{/if}}
                            <p class="mt-1 text-muted mb-0"><small>{{descripcion}} (Formato: {{formato}})</small></p>
                        </div>
                    {{/each}}
                {{else}}
                    <p class="text-muted fst-italic">No hay contenido multimedia adjunto.</p>
                {{/if}}
                <a href="/hechos/{{hecho.id}}/multimedia/nuevo" class="btn btn-sm btn-outline-primary mt-2">Agregar Multimedia</a>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h3>Solicitar Eliminación</h3></div>
        <div class="card-body">
            <form action="/hechos/{{hecho.id}}/solicitudes/nueva" method="GET">
                <p>Si consideras que este hecho debe ser eliminado, puedes iniciar una solicitud.</p>
                <button type="submit" class="btn btn-danger">Iniciar Solicitud de Eliminación</button>
            </form>
        </div>
    </div>
{{else}}
    <div class="alert alert-danger">Hecho no encontrado.</div>
{{/if}}

<script>
    if (typeof Handlebars !== 'undefined' && !Handlebars.helpers.eq) {
        Handlebars.registerHelper('eq', function (a, b) {
            return a === b;
        });
    }
</script>

</body>
</html>