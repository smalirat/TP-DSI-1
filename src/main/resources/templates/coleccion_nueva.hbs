<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Nueva Colección</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/templates/static/base.css">
    <link rel="stylesheet" href="/templates/static/components.css">
    <link rel="stylesheet" href="/templates/static/pages/colecciones.css">
</head>
<body style="background: #f8f6f2; min-height: 100vh;">

<!-- Include Admin Navbar -->
{{> navbar_admin}}

<div class="container-fluid py-5">
    <h1 class="display-5 fw-bold mb-4" style="color: #333;">Crear Nueva Colección</h1>
    <p class="subtitle">Define los detalles de la nueva colección y selecciona una fuente de datos.</p>

    <form action="/admin/colecciones" method="POST" class="mt-4">
    
    <div class="mb-3">
        <label for="fuenteId" class="form-label">Fuente de Datos</label>
        <select id="fuenteId" name="fuenteId" class="form-select" required>
            <option value="">-- Selecciona una fuente --</option>
            {{#each fuentes}}
                <option value="{{id}}">Fuente ID {{id}} - Tipo: {{tipo}}</option>
            {{/each}}
        </select>
        <div class="form-text">Selecciona la fuente de datos que proporcionará los hechos para esta colección.</div>
    </div>

    <div class="mb-3">
        <label for="titulo" class="form-label">Título de la Colección</label>
        <input type="text" class="form-control" id="titulo" name="titulo" required>
    </div>
    <div class="mb-3">
        <label for="descripcion" class="form-label">Descripción</label>
        <textarea class="form-control" id="descripcion" name="descripcion" rows="3"></textarea>
    </div>
    <div class="mb-3">
        <label for="handle" class="form-label">Handle (identificador único)</label>
        <input type="text" class="form-control" id="handle" name="handle" pattern="[a-zA-Z0-9]+" title="Solo letras y números, sin espacios" required>
        <div class="form-text">Se usará en la URL. Ej: /colecciones/{{handle}}.</div>
    </div>

    <div class="mb-3">
        <label for="algoritmoConsenso" class="form-label">Algoritmo de Consenso (Modo Curado)</label>
        <select id="algoritmoConsenso" name="algoritmoConsenso" class="form-select">
            <option value="NINGUNO">Ninguno (Modo Irrestricto)</option>
            {{#each algoritmos}}
                <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <div class="form-text">Si selecciona un algoritmo, la colección se mostrará en Modo Curado.</div>
    </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Guardar Colección</button>
            <a href="/admin/colecciones" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

</body>
</html>