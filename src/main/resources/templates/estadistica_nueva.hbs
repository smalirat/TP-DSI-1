<!DOCTYPE html>
<html>
<head>
    <title>Generar Estadística - MetaMapa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<h1>Generar Nueva Estadística</h1>
<p>Selecciona el tipo de reporte que deseas generar y completa los campos requeridos.</p>

<form action="/admin/estadisticas" method="POST" class="mt-4">
    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre del Reporte *</label>
        <input type="text" class="form-control" id="nombre" name="nombre" required>
    </div>

    <div class="mb-3">
        <label for="tipo" class="form-label">Tipo de Estadística *</label>
        <select id="tipo" name="tipo" class="form-select" required onchange="mostrarCamposDinamicos(this.value)">
            <option value="">Seleccionar tipo...</option>
            {{#each tipos}}
                <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
    </div>

    <div class="mb-3" id="campoCategoria" style="display:none;">
        <label for="categoria" class="form-label">Categoría Requerida</label>
        <select id="categoria" name="categoria" class="form-select">
            <option value="">Seleccionar categoría...</option>
            {{#each todasLasCategorias}}
                <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
    </div>

    <div class="mb-3" id="campoColeccion" style="display:none;">
        <label for="coleccionHandle" class="form-label">Colección Requerida</label>
        <select id="coleccionHandle" name="coleccionHandle" class="form-select">
            <option value="">Seleccionar colección...</option>
            {{#each todasLasColecciones}}
                <option value="{{handle}}">{{titulo}} ({{handle}})</option>
            {{/each}}
        </select>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="esPublica" id="esPublica" value="true" checked>
        <label class="form-check-label" for="esPublica">
            Marcar como Pública
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Generar y Guardar</button>
    <a href="/admin/estadisticas" class="btn btn-secondary">Cancelar</a>
</form>

<script>
    function mostrarCamposDinamicos(tipo) {
        const campoCategoria = document.getElementById('campoCategoria');
        const campoColeccion = document.getElementById('campoColeccion');

        const necesitaCategoria = tipo === 'PROVINCIA_MAS_HECHOS_POR_CATEGORIA' || tipo === 'HORA_PICO_POR_CATEGORIA';
        const necesitaColeccion = tipo === 'HECHOS_POR_PROVINCIA_COLECCION';

        campoCategoria.style.display = necesitaCategoria ? 'block' : 'none';
        document.getElementById('categoria').required = necesitaCategoria;

        campoColeccion.style.display = necesitaColeccion ? 'block' : 'none';
        document.getElementById('coleccionHandle').required = necesitaColeccion;
    }
</script>

</body>
</html>

